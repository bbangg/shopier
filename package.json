{
  "name": "@bbangg/shopier",
  "version": "1.0.6",
  "description": "Unofficial Shopier SDK",
  "author": "bbangg",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "shopier",
    "sdk",
    "api",
    "ecommerce",
    "typescript",
    "node",
    "payment"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbangg/shopier.git"
  },
  "bugs": {
    "url": "https://github.com/bbangg/shopier/issues"
  },
  "homepage": "https://github.com/bbangg/shopier#readme"
}